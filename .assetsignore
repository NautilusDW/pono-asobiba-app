# deploy 重量削減 (2026-07-10 perf audit)
# - assets/_legacy_png/: webp 化前の PNG rollback 退避 (~32MB)。 コメント以外の参照ゼロを grep 確認済。
# - StickerBookThreeJS/screenshots/: 開発用スクショ (~75MB)。 参照ゼロを grep 確認済。
# - assets/_legacy/ は quizland ほか複数ページの preview-placeholders 参照が残るため除外しない。
assets/_legacy_png/
Prototypes/StickerBookThreeJS/screenshots/

# ローカル専用 Unity 生成物 (.gitignore と同じ集合。 git 追跡外なので CI checkout には
# 存在せず、 これを足しても CI デプロイのアセット集合と同一のまま)。
# ローカルからの手動 `wrangler deploy` 時、 アセット走査が 25MiB 超ファイル
# (unity/**/Library/ArtifactDB 35.4MiB 等) で失敗するのを防ぐ (2026-07-10)。
unity/**/Library/
unity/**/library/
unity/**/Temp/
unity/**/temp/
unity/**/Obj/
unity/**/obj/
unity/**/Logs/
unity/**/logs/
unity/**/UserSettings/
unity/**/Builds/
unity/**/builds/
unity/**/MemoryCaptures/
unity/**/.utmp/
unity/**/Recordings/
unity/**/sysinfo.txt
unity/**/*.csproj
unity/**/*.sln
unity/**/*.slnx
unity/**/*.user
unity/**/.vscode/
unity/**/.idea/
unity/**/.vs/
.DS_Store
