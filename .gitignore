node_modules/

# Local Netlify folder
.netlify

# Cloudflare wrangler local env (secrets)
.dev.vars
.wrangler/

# Local backup of oversized original assets (kept out of the deploy tree).
_backups/
assets/**/*_orig_backup.png
assets/**/*_backup.png
assets/_orig_image_backup/

# auto_optimize_image.py のキャッシュ/ログ (ローカル状態)
scripts/.image_opt_cache.json
scripts/.image_opt_cache.log
assets/**/*.opt.tmp

# docs_review_hook.py の sentinel + state log (v2 で state-dir 化)
.claude/.docs-review-pending
.claude/.docs-skip-once
.claude/.docs-hook-state/

# 診断・一時ファイル（auto-commit でリポジトリに混入するのを防ぐ）
_tmp*
_tmp_*
tmp/
*.diff
le-*.diff
_scratch*
_debug*
.staging_*
.staging_*.html

# Hybrid Stop hook (Option D) sentinel + debounce state
.claude/.has-edits
.claude/.last-push

# Claude Code agent worktree submodules — internal state, not part of the app
.claude/worktrees/

# Local debug log (was historically tracked; now ignored)
debug.log

# Playwright E2E harness artifacts
test-results/
playwright-report/
# Visual snapshot baselines — keep tracked for now (uncomment to ignore):
# tests/e2e/**/*-snapshots/

# Screenshot capture tmp files (manual visual check artifacts, not for repo)
tmp_capture_*.png
tmp_capture_*.json
_visual_capture*.mjs
_capture_*.mjs
_capture_tmp/

# Capacitor native shell (Phase 1 scaffold) — generated / local-only artifacts.
# Source (native/package.json, native/capacitor.config.json, native/scripts/**)
# stays tracked; the staged www build and Android project build state do not.
native/www/
native/node_modules/
native/android/.gradle/
native/android/**/build/
native/android/local.properties

# Capacitor native shell (Phase 2 scaffold: iOS) — generated / local-only
# artifacts. Nested native/ios/.gitignore (auto-generated by `cap add ios`)
# already covers most Xcode/CocoaPods noise (Pods/, DerivedData/, xcuserdata/,
# generated config files, etc). The entries below are kept here too as
# defense-in-depth, especially native/ios/App/App/public/ — the synced copy
# of native/www/ that is the single biggest generated blob (~1.1GB).
native/ios/App/App/public/
native/ios/App/Pods/
native/ios/DerivedData/
native/ios/**/xcuserdata/
native/ios/**/*.xcuserstate

# Standalone Unity prototypes — keep source/settings, ignore generated state.
unity/**/[Ll]ibrary/
unity/**/[Tt]emp/
unity/**/[Oo]bj/
unity/**/[Ll]ogs/
unity/**/[Uu]ser[Ss]ettings/
unity/**/[Bb]uilds/
unity/**/[Mm]emoryCaptures/
unity/**/*.csproj
unity/**/*.sln
unity/**/*.slnx
unity/**/*.user
unity/**/.vscode/
unity/**/.idea/
unity/**/.vs/
unity/**/.utmp/
unity/**/Recordings/
unity/**/sysinfo.txt
