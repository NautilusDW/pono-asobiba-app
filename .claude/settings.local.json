  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python d:/claude-rl-test/scripts/observe.py --hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'DEPLOY-FACT (do not contradict): pono-asobiba-app は Cloudflare Workers で配信。Netlify は完全廃止 — Netlify という単語・コマンド・URL を提案/コマンド/回答に出さない。staging=https://pono-asobiba-staging.ndw.workers.dev/ (develop自動)、production=https://pono.kodama-no-mori.com/ (master明示時のみ)。手動デプロイは wrangler deploy --env staging または wrangler deploy。'"
          }
        ]
      }
    ]
  }
}
