  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python d:/claude-rl-test/scripts/observe.py --hook"
          },
          {
            "type": "command",
            "command": "python d:/AppDevelopment/pono-asobiba-app/scripts/auto_optimize_image.py --hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'DEPLOY-FACT (do not contradict): pono-asobiba-app は Cloudflare Workers で配信。Netlify は完全廃止 — Netlify という単語・コマンド・URL を提案/コマンド/回答に出さない。単一トランク = develop-app: push で App staging=https://pono-asobiba-app-staging.ndw.workers.dev/ と LP staging=https://pono-asobiba-staging.ndw.workers.dev/ の両方へ自動デプロイ。develop ブランチは凍結済み (push しない)。production=https://pono.kodama-no-mori.com/ と https://pono-asobiba-app.ndw.workers.dev/ (master 明示マージ時のみ)。手動デプロイは wrangler deploy --env staging-app / --env staging / 本番は wrangler deploy。'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'ORCHESTRATOR-MODE: あなたは全体の進捗と品質管理に徹底し、 タスクは直接行わないこと。 実装はエージェントチームを組成して並列で。 レビューは必ずエージェント同士のクロスレビューを実施。 このルールは違反すると user 信頼を失う。'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python d:/AppDevelopment/pono-asobiba-app/scripts/image_review_reminder.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd /d/AppDevelopment/pono-asobiba-app && branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) && if [ \"$branch\" = \"develop-app\" ]; then ahead=$(git log origin/develop-app..develop-app --oneline 2>/dev/null | wc -l); if [ \"$ahead\" -gt 0 ]; then echo \"[auto-push] $ahead 個の未 push commit を origin/develop-app に push します\"; git push origin develop-app 2>&1 | tail -3; else true; fi; fi"
          }
        ]
      }
    ]
  }
}
