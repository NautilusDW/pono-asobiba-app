{
  "permissions": {
    "allow": [
      "Bash(python scripts/orchestrator.py *)",
      "Bash(python scripts/observe.py *)",
      "Bash(python scripts/analyze.py *)",
      "Bash(python scripts/evolve.py *)",
      "Bash(python -m pytest *)",
      "Bash(pip install *)",
      "Bash(python scripts/orchestrator.py complete --task \"Phase1をトランスクリプト直接解析に切替\" --result success)",
      "Bash(python scripts/orchestrator.py complete --task \"消費税計算add_tax関数の追加とテスト\" --result success)",
      "Bash(find d:/claude-rl-test/logs -type f ! -name '.gitkeep' -delete)",
      "WebSearch",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:www.mattmontag.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:ai.google.dev)",
      "WebFetch(domain:docs.cloud.google.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:pono-asobiba-staging.ndw.workers.dev)",
      "WebFetch(domain:pono-asobiba-app.ndw.workers.dev)",
      "WebFetch(domain:pono.kodama-no-mori.com)",
      "Bash(mkdir -p ~/.claude/sessions)",
      "Read(//c/Users/surfe/.claude/sessions/**)",
      "WebFetch(domain:docs.spline.design)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:cdn.jsdelivr.net)",
      "Bash(netstat -ano)",
      "WebFetch(domain:www.amnh.org)",
      "WebFetch(domain:pbskids.org)",
      "WebFetch(domain:www.smithsonianmag.com)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(mkdir -p .claude)",
      "Bash(touch .claude/.docs-skip-once)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:community.openai.com)",
      "WebFetch(domain:memu.pro)",
      "WebFetch(domain:rajiv.com)",
      "WebFetch(domain:help.figma.com)",
      "WebFetch(domain:forum.figma.com)",
      "WebFetch(domain:www.figma.com)",
      "Bash(mkdir -p d:/AppDevelopment/pono-asobiba-app/.claude)",
      "Bash(touch d:/AppDevelopment/pono-asobiba-app/.claude/.docs-skip-once)",
      "Bash(git ls-remote *)",
      "WebFetch(domain:www.ah-soft.com)",
      "Bash(:)",
      "Bash(mkdir -p \"d:/AppDevelopment/pono-asobiba-app/.claude\")",
      "Bash(touch \"d:/AppDevelopment/pono-asobiba-app/.claude/.docs-skip-once\")"
    ],
    "additionalDirectories": [
      "D:\\AppDevelopment\\pono-asobiba-app\\.claude"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python d:/claude-rl-test/scripts/observe.py --hook"
          },
          {
            "type": "command",
            "command": "python d:/AppDevelopment/pono-asobiba-app/scripts/auto_optimize_image.py --hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'DEPLOY-FACT (do not contradict): pono-asobiba-app は Cloudflare Workers で配信。Netlify は完全廃止 — Netlify という単語・コマンド・URL を提案/コマンド/回答に出さない。staging=https://pono-asobiba-staging.ndw.workers.dev/ (develop自動)、production=https://pono.kodama-no-mori.com/ (master明示時のみ)。手動デプロイは wrangler deploy --env staging または wrangler deploy。'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'ORCHESTRATOR-MODE: あなたは全体の進捗と品質管理に徹底し、 タスクは直接行わないこと。 実装はエージェントチームを組成して並列で。 レビューは必ずエージェント同士のクロスレビューを実施。 このルールは違反すると user 信頼を失う。'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd /d/AppDevelopment/pono-asobiba-app && branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) && if [ \"$branch\" = \"develop\" ]; then ahead=$(git log origin/develop..develop --oneline 2>/dev/null | wc -l); if [ \"$ahead\" -gt 0 ]; then echo \"[auto-push] $ahead 個の未 push commit を origin/develop に push します\"; git push origin develop 2>&1 | tail -3; else true; fi; fi"
          }
        ]
      }
    ]
  }
}
